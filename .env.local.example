# ============================================
# iBlood Blood Bank Management System
# Environment Variables Configuration
# ============================================
# Copy this file to .env.local and fill in your values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get from: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# MONGODB CONFIGURATION
# ============================================
# Get from: MongoDB Atlas or your MongoDB provider
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/iblood

# ============================================
# APPLICATION CONFIGURATION
# ============================================
# Production URL (Netlify/Vercel URL)
NEXT_PUBLIC_APP_URL=https://your-domain.com
# For local development, use: http://localhost:3000

# Network Configuration
# Add your production IPs/domains for allowed origins
ALLOWED_ORIGINS=your-domain.com,api.your-domain.com

# Node Environment
NODE_ENV=development

# ============================================
# GOOGLE OAUTH CONFIGURATION (Optional)
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
# Required for "Login with Google" feature
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.com/auth/callback/google

# ============================================
# OTP/SMS CONFIGURATION (Twilio - Primary)
# ============================================
# Get credentials from: https://www.twilio.com/try-twilio
# Free tier: $15 credit (~750 SMS)
# OPTIONAL - if not configured, will fallback to email

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# EMAIL CONFIGURATION (Gmail App Password - Backup)
# ============================================
# Setup:
# 1. Go to Google Account → Security
# 2. Enable 2-Step Verification
# 3. Generate App Password: https://myaccount.google.com/apppasswords
# 4. Use 16-character password (no spaces)
# OPTIONAL - if not configured, will fallback to console

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop  # 16 chars, no spaces

# ============================================
# MAILJET BACKUP (Optional - Secondary Backup)
# ============================================
# Get API keys from: https://app.mailjet.com/account/apikeys
# Free tier: 6,000 emails/month (200/day)
# OPTIONAL - only needed if Gmail fails

MAILJET_API_KEY=your-api-key
MAILJET_SECRET_KEY=your-secret-key
MAILJET_FROM_EMAIL=verified-email@yourdomain.com

# ============================================
# CLOUDINARY CONFIGURATION (File Uploads)
# ============================================
# Get from: https://cloudinary.com/users/register/free
# Used for profile pictures, drive images, etc.
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ============================================
# ADMIN SETUP CONFIGURATION
# ============================================
# Email for the default super admin account
# This user will be created on first setup
DEFAULT_ADMIN_EMAIL=your-email@example.com

# ============================================
# RATE LIMITING (Optional)
# ============================================
# Configure rate limiting for API endpoints
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# SESSION CONFIGURATION (Optional)
# ============================================
# Session cookie settings
SESSION_MAX_AGE=86400000
SESSION_COOKIE_NAME=auth-session-token

# ============================================
# AUDIT LOGGING (Optional)
# ============================================
# Enable/disable audit logging
ENABLE_AUDIT_LOGGING=true

# ============================================
# NOTES:
# ============================================
# 1. Never commit .env.local to version control
# 2. OTP will try: Twilio SMS → Gmail Email → Mailjet → Console (demo)
# 3. For demo/testing, OTP is always logged to console as fallback
# 4. Restart dev server after changing environment variables
# 5. All OTP services are OPTIONAL - console fallback always works for testing
# 6. Google OAuth is OPTIONAL - standard email/password auth works without it
# 7. Cloudinary is OPTIONAL - file uploads can be disabled if not needed
# ============================================
